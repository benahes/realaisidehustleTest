# ============================================
# RAISH Environment Variables
# Copy to .env.local for development
# Never commit .env.local to git
# ============================================

# --- App Base ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Database (Railway PostgreSQL or Supabase) ---
DATABASE_URL="postgresql://user:pass@localhost:5432/raish?schema=public"

# --- Redis (Railway or local) ---
REDIS_URL="redis://localhost:6379"

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Cloudflare R2 (File Storage) ---
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="raish-assets"
CLOUDFLARE_R2_PUBLIC_URL="https://assets.raish.com"

# --- Cloudflare Stream (Video) ---
CLOUDFLARE_STREAM_TOKEN=""
CLOUDFLARE_STREAM_ACCOUNT_ID=""

# --- Payments ---
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-..."

# --- Newsletter / Email ---
RESEND_API_KEY="re_..."

# --- AI ---
GROK_API_KEY="xai-..."
OPENAI_API_KEY="sk-..."

# --- Monitoring ---
SENTRY_DSN=""

# --- Legacy ---
GEMINI_API_KEY=""
